generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ETABLISSEMENT
  RESPONSABLE
}

enum DevisStatus {
  BROUILLON
  ENVOYE
  APPROUVE
  SUSPENDU
  REJETE
  ACCEPTE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      UserRole
  firstName String?
  lastName  String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  etablissement  Etablissement?
  createdDevis   Devis[] @relation("CreatedBy")
  validatedDevis Devis[] @relation("ValidatedBy")

  @@map("users")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@map("categories")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("TND")
  stock       Int      @default(0)
  image       Bytes?   // Stocker l'image en binaire (Base64)
  imageType   String?  @db.VarChar(50)  // Type MIME : "image/png", "image/jpeg", etc.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("products")
}

model Etablissement {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  address   String?  @db.Text
  phone     String?  @db.VarChar(20)
  email     String?  @db.VarChar(255)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("etablissements")
}

model Devis {
  id            String      @id @default(uuid())
  total         Decimal     @db.Decimal(10, 2)
  status        DevisStatus @default(BROUILLON)
  clientName    String      @db.VarChar(255)
  clientEmail   String      @db.VarChar(255)
  clientPhone   String?     @db.VarChar(20)
  clientAddr    String?     @db.Text
  createdById   String
  createdBy     User        @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  validatedById String?
  validatedBy   User?       @relation("ValidatedBy", fields: [validatedById], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items DevisItem[]

  @@map("devis")
}

model DevisItem {
  id        String  @id @default(uuid())
  devisId   String
  productId Int
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  devis Devis @relation(fields: [devisId], references: [id], onDelete: Cascade)

  @@map("devis_items")
}