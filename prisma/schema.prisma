generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ETABLISSEMENT
  RESPONSABLE
}

enum DevisStatus {
  EN_ATTENTE
  APPROUVE
  SUSPENDU
  REJETE
  
}

enum AdminDevisStatus {
  EN_COURS_DE_FACTURATION
  EN_COURS_DE_LIVRAISON
  LIVREE
  REJETE
}

enum StockStatus {
  DISPONIBLE
  HORS_STOCK
}

enum NotificationType {
  DEVIS_CREATED
  DEVIS_STATUS_CHANGED
  DEVIS_APPROVED
  DEVIS_REJECTED
}

model User {
  id    String   @id @default(uuid())
  email String   @unique
  password  String
  role      UserRole
  firstName String?
  lastName  String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation to etablissement - User can belong to one etablissement
  etablissementId String?
  etablissement   Etablissement? @relation("UserToEtablissement", fields: [etablissementId], references: [id], onDelete: SetNull)

  // Relations pour les devis
  createdDevis      Devis[] @relation("CreatedBy")
  validatedDevis    Devis[] @relation("ValidatedBy")
  adminValidatedDevis Devis[] @relation("AdminValidatedBy")

  // Notifications
  notifications Notification[]

  @@map("lg_dbusers")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@map("categories")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("TND")
  stock       StockStatus @default(DISPONIBLE)
  image       Bytes?
  imageType   String?  @db.VarChar(50)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  devisItems DevisItem[]

  @@map("products")
}

model Etablissement {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  address   String?  @db.Text
  phone     String?  @db.VarChar(20)
  email     String?  @db.VarChar(255)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Hiérarchie d'établissements - Self-referencing relation
  parentId  String?
  parent    Etablissement? @relation("ParentChild", fields: [parentId], references: [id], onDelete: SetNull)
  children  Etablissement[] @relation("ParentChild")

  // Multiple users can belong to this etablissement
  users User[] @relation("UserToEtablissement")
  devis Devis[]

  @@map("etablissements")
}

model Devis {
  id              String      @id @default(uuid())
  total           Decimal     @db.Decimal(10, 2)
  
  // Statuts séparés pour Responsable et Admin
  responsableStatus DevisStatus @default(EN_ATTENTE)
  adminStatus       AdminDevisStatus @default(EN_COURS_DE_FACTURATION)

  // Client information
  clientName      String      @db.VarChar(255)
  clientEmail     String      @db.VarChar(255)
  clientPhone     String?     @db.VarChar(20)
  clientAddr      String?     @db.Text
  clientEnterprise String?     @db.VarChar(255)
  clientNotes     String?     @db.Text

  // ✅ PDF fields for invoice/facture download
  invoicePdf      Bytes?      @db.LongBlob
  invoicePdfName  String?     @db.VarChar(255)
  invoicePdfType  String?     @db.VarChar(50)
  invoicePdfUploadedAt DateTime?

  // Relations
  createdById     String
  createdBy       User        @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  validatedById   String?
  validatedBy     User?       @relation("ValidatedBy", fields: [validatedById], references: [id], onDelete: SetNull)

  adminValidatedById   String?
  adminValidatedBy     User?   @relation("AdminValidatedBy", fields: [adminValidatedById], references: [id], onDelete: SetNull)

  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           DevisItem[]
  notifications   Notification[]

  @@map("devis")
}

model DevisItem {
  id        String  @id @default(uuid())
  devisId   String
  productId Int
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  devis   Devis   @relation(fields: [devisId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("devis_items")
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        NotificationType
  title       String   @db.VarChar(255)
  message     String   @db.Text
  
  devisId     String?
  devis       Devis?   @relation(fields: [devisId], references: [id], onDelete: SetNull)
  
  isRead      Boolean  @default(false)
  readAt      DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("notifications")
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}
